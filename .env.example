# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# IMPORTANT: Ensure all sensitive credentials are in your .env file, not in code!

# AI Configuration - Get your API key from your AI provider
AI_API_KEY=<your-ai-api-key>
REACT_APP_AI_API_KEY=<your-ai-api-key>

# Firebase Configuration — https://console.firebase.google.com/
# WARNING: Firebase API Key must be in .env, never hardcode in source files
VITE_FIREBASE_API_KEY=<your-firebase-api-key>
VITE_FIREBASE_AUTH_DOMAIN=<your-project>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<your-project-id>
VITE_FIREBASE_STORAGE_BUCKET=<your-project>.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=<your-sender-id>
VITE_FIREBASE_APP_ID=<your-app-id>
VITE_FIREBASE_MEASUREMENT_ID=<your-measurement-id>

# Supabase Configuration — https://supabase.com/
# WARNING: Supabase keys must be in .env, never hardcode in source files
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-anon-key>
VITE_SUPABASE_PROJECT_ID=<project-ref>
VITE_API_BASE_URL=http://localhost:3001

# OpenWeatherMap — https://openweathermap.org/api
VITE_OWM_API_KEY=<your-openweathermap-api-key>
