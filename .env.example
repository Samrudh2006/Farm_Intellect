# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# SECURITY MODEL:
# - VITE_* values are public and are bundled into browser code.
# - Keep only publishable client values here.
# - Keep all sensitive keys in backend/.env.

# Supabase client configuration (public-safe)
VITE_SUPABASE_URL=https://pkciruwarpgngekkxafy.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_pAeD7Lrg8gNGPhKrzE4-Ng_UMCxEcNv
# Optional alias supported by the app; same value as publishable key
VITE_SUPABASE_ANON_KEY=sb_publishable_pAeD7Lrg8gNGPhKrzE4-Ng_UMCxEcNv
VITE_SUPABASE_PROJECT_ID=pkciruwarpgngekkxafy

# Express API base URL for frontend
VITE_API_BASE_URL=http://localhost:3001

# Robots policy injected into index.html at build time.
# Use "index, follow" for production and "noindex, nofollow" for preview/staging.
VITE_ROBOTS_POLICY=noindex, nofollow

# Optional frontend Sentry DSN (public DSN only)
VITE_SENTRY_DSN=
