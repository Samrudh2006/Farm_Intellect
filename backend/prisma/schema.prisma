// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_LOCAL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  location      String?
  role          UserRole
  isVerified    Boolean   @default(false)
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  profileImage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  documents       Document[]
  otpCodes        OtpCode[]
  notifications   Notification[]
  posts           Post[]
  comments        Comment[]
  chatMessages    ChatMessage[]
  activities      Activity[]
  farmerProfile   FarmerProfile?
  merchantProfile MerchantProfile?
  expertProfile   ExpertProfile?
  fields          Field[]
  pollVotes       PollVote[]
  notificationPreference NotificationPreference?
  deviceTokens    DeviceToken[]

  @@map("users")
}

model FarmerProfile {
  id          String @id @default(uuid())
  userId      String @unique
  farmSize    Float?
  cropTypes   String? // JSON array of crop types
  experience  Int? // years of experience
  latitude    Float?
  longitude   Float?
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("farmer_profiles")
}

model MerchantProfile {
  id           String @id @default(uuid())
  userId       String @unique
  businessName String?
  businessType String?
  yearsInBusiness Int?
  rating       Float? @default(0)
  latitude     Float?
  longitude    Float?
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("merchant_profiles")
}

model ExpertProfile {
  id             String @id @default(uuid())
  userId         String @unique
  specialization String?
  experience     Int? // years of experience
  rating         Float? @default(0)
  consultations  Int? @default(0)
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expert_profiles")
}

model Document {
  id           String       @id @default(uuid())
  userId       String
  type         DocumentType
  fileName     String
  filePath     String
  originalName String
  mimeType     String
  size         Int
  isVerified   Boolean      @default(false)
  verifiedAt   DateTime?
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt])
  @@map("documents")
}

model OtpCode {
  id        String    @id @default(uuid())
  userId    String
  code      String
  type      OtpType
  purpose   String // signup, login, reset-password, critical-action
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  data      String? // JSON data for additional context
  deletedAt DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, deletedAt])
  @@map("notifications")
}

model Post {
  id          String    @id @default(uuid())
  authorId    String
  title       String
  content     String
  category    String
  tags        String? // JSON array
  likes       Int       @default(0)
  views       Int       @default(0)
  isApproved  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]

  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model ChatMessage {
  id        String      @id @default(uuid())
  userId    String
  message   String
  type      MessageType @default(USER)
  context   String? // JSON context for AI responses
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt, deletedAt])
  @@map("chat_messages")
}

model Activity {
  id          String       @id @default(uuid())
  userId      String
  action      String
  description String
  entityType  String? // crop, order, consultation, etc.
  entityId    String?
  metadata    String? // JSON metadata
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model CropCalendar {
  id          String   @id @default(uuid())
  userId      String
  cropType    String
  plantingDate DateTime
  harvestDate DateTime?
  stage       String
  reminders   String? // JSON array of reminders
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, deletedAt])
  @@map("crop_calendar")
}

model Field {
  id          String   @id @default(uuid())
  ownerId     String?
  name        String
  area        String
  crop        String
  health      Int
  lastUpdated DateTime
  coordinates Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sensors Sensor[]
  owner   User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@map("fields")
}

model Sensor {
  id          String   @id @default(uuid())
  fieldId     String?
  name        String
  type        String
  location    String
  status      String
  battery     Int
  lastReading DateTime?
  value       Float
  unit        String
  optimal     Json?
  coordinates Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  field Field? @relation(fields: [fieldId], references: [id], onDelete: SetNull)

  @@map("sensors")
}

model Merchant {
  id          String   @id @default(uuid())
  name        String
  company     String?
  location    String
  distance    String?
  rating      Float?
  phone       String?
  specialties Json?
  crops       Json?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("merchants")
}

model CropDemand {
  id           String   @id @default(uuid())
  crop         String
  avgPrice     Float
  merchants    Int
  trend        String
  recommendation String
  lastUpdated  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("crop_demand")
}

model Poll {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  status      String
  creator     String
  region      String
  createdAt   DateTime @default(now())
  endDate     DateTime?

  options PollOption[]
  votes   PollVote[]

  @@map("polls")
}

model PollOption {
  id      String @id @default(uuid())
  pollId  String
  text    String
  votes   Int    @default(0)

  poll  Poll      @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votesRecords PollVote[]

  @@map("poll_options")
}

model PollVote {
  id       String   @id @default(uuid())
  pollId   String
  optionId String
  userId   String
  createdAt DateTime @default(now())

  poll   Poll      @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@map("poll_votes")
}

model DatasetMetadata {
  id          String   @id @default(uuid())
  key         String   @unique
  version     String
  lastUpdated DateTime
  source      String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("dataset_metadata")
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @unique
  email     Boolean  @default(true)
  sms       Boolean  @default(false)
  whatsapp  Boolean  @default(false)
  push      Boolean  @default(true)
  inApp     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

model MandiPrice {
  id         String   @id @default(uuid())
  crop       String
  market     String
  price      Float
  unit       String
  trend      String?
  region     String?
  recordedAt DateTime
  source     String?
  createdAt  DateTime @default(now())

  @@map("mandi_prices")
}

model WeatherSnapshot {
  id          String   @id @default(uuid())
  location    String
  temperature Float?
  humidity    Float?
  rainfall    Float?
  advisory    String?
  recordedAt  DateTime
  source      String?
  payload     Json?
  createdAt   DateTime @default(now())

  @@map("weather_snapshots")
}

model IngestionLog {
  id         String   @id @default(uuid())
  datasetKey String
  status     String
  message    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@map("ingestion_logs")
}

model AIRecommendation {
  id          String   @id @default(uuid())
  userId      String
  type        String // crop, fertilizer, pest-control, etc.
  title       String
  description String
  confidence  Float
  data        String? // JSON data
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("ai_recommendations")
}

enum UserRole {
  FARMER
  MERCHANT
  EXPERT
  ADMIN
}

enum DocumentType {
  ID_PROOF
  ADDRESS_PROOF
  LAND_RECORDS
  BUSINESS_LICENSE
  OTHER
}

enum OtpType {
  EMAIL
  SMS
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  REMINDER
}

enum MessageType {
  USER
  AI_ASSISTANT
}
