{
  "name": "farm-intellect-backend",
  "version": "1.0.0",
  "description": "Backend for Farm Intellect application",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "echo 'No build step needed for Node.js'",
    "test": "cross-env NODE_ENV=test vitest run",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:migrate:status": "npx prisma migrate status",
    "db:seed": "node prisma/seed.js",
    "db:push": "node -e \"console.error('Blocked: use Prisma migrations instead (db:migrate or db:migrate:deploy).'); process.exit(1);\"",
    "db:studio": "npx prisma studio"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@sentry/node": "^8.33.1",
    "@supabase/supabase-js": "^2.57.4",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.5.0",
    "follow-redirects": "^1.16.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.18.1",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.10",
    "path-to-regexp": "^8.4.2",
    "prisma": "^5.7.1",
    "prom-client": "^15.1.3",
    "qs": "^6.15.2",
    "socket.io": "^4.8.3",
    "twilio": "^4.19.0",
    "uuid": "^14.0.0",
    "winston": "^3.11.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "vite": "^8.0.15",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "socket.io-parser": "4.2.6",
    "qs": "$qs",
    "protobufjs": "7.5.8",
    "ws": "$ws",
    "uuid": "$uuid",
    "picomatch": "^4.0.4"
  }
}
