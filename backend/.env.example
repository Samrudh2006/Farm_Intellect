PORT=3001
NODE_ENV=development
APP_ENV=local
FRONTEND_URL=http://localhost:5173

# Database
# Use separate credentials per environment. Never reuse production credentials in local/staging.
DATABASE_URL_LOCAL=postgresql://user:password@localhost:5432/farm_intellect_local?schema=public
DATABASE_URL_STAGING=postgresql://user:password@staging-host:5432/farm_intellect_staging?schema=public
DATABASE_URL_PRODUCTION=postgresql://user:password@prod-host:5432/farm_intellect_prod?schema=public
# Optional legacy fallback for local/test only.
DATABASE_URL=

# Auth
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_FILE_SIZE=10485760
CLAMAV_PATH=
MAINTENANCE_MODE=false
FORCE_HTTPS=true

# Notifications
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
TWILIO_ACCOUNT_SID_LOCAL=
TWILIO_ACCOUNT_SID_STAGING=
TWILIO_ACCOUNT_SID_PRODUCTION=
TWILIO_AUTH_TOKEN_LOCAL=
TWILIO_AUTH_TOKEN_STAGING=
TWILIO_AUTH_TOKEN_PRODUCTION=
TWILIO_MESSAGING_SERVICE_SID_LOCAL=
TWILIO_MESSAGING_SERVICE_SID_STAGING=
TWILIO_MESSAGING_SERVICE_SID_PRODUCTION=
TWILIO_SMS_FROM_LOCAL=
TWILIO_SMS_FROM_STAGING=
TWILIO_SMS_FROM_PRODUCTION=
TWILIO_WHATSAPP_FROM_LOCAL=
TWILIO_WHATSAPP_FROM_STAGING=
TWILIO_WHATSAPP_FROM_PRODUCTION=

# Supabase Auth (optional for backend token validation)
SUPABASE_URL_LOCAL=
SUPABASE_URL_STAGING=
SUPABASE_URL_PRODUCTION=
SUPABASE_ANON_KEY_LOCAL=
SUPABASE_ANON_KEY_STAGING=
SUPABASE_ANON_KEY_PRODUCTION=

# Ingestion
OWM_API_KEY=
WEATHER_LOCATIONS=Ludhiana,IN|Pune,IN
MANDI_API_URL=
MANDI_API_KEY=

# Background jobs
ENABLE_SCHEDULED_JOBS=false
ENABLE_METRICS=true

# Error monitoring
SENTRY_DSN=

# External inference runtime
INFERENCE_SERVICE_URL=
INFERENCE_SERVICE_TOKEN=
