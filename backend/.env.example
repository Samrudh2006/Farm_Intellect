PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/farm_intellect?schema=public

# Auth
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_FILE_SIZE=10485760
CLAMAV_PATH=

# Notifications
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# Ingestion
OWM_API_KEY=
WEATHER_LOCATIONS=Ludhiana,IN|Pune,IN
MANDI_API_URL=
MANDI_API_KEY=

# Background jobs
ENABLE_SCHEDULED_JOBS=false
ENABLE_METRICS=true

# Error monitoring
SENTRY_DSN=

# External inference runtime
INFERENCE_SERVICE_URL=
INFERENCE_SERVICE_TOKEN=
